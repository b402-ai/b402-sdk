# Required — operator private key (derives anonymous smart wallet)
WORKER_PRIVATE_KEY=0x...

# Optional — override RPC endpoints (defaults work for testing)
# BASE_RPC_URL=
# ARB_RPC_URL=
# BSC_RPC_URL=

# Optional — override facilitator
# FACILITATOR_URL=

# Optional — override backend API (UTXO indexer)
# BASE_BACKEND_API_URL=
# ARB_BACKEND_API_URL=
